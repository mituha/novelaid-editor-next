{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-appconfig-read",
    "fs:allow-appconfig-write",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-appconfig-write-recursive",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "novelaid-fs:default"
  ]
}